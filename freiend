<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>채은이의 친구 신청</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Noto Sans KR', sans-serif;
      background: linear-gradient(135deg, #ffe0f0 0%, #ffd6f0 40%, #e8d5ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .card {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px);
      border-radius: 32px;
      padding: 3rem 3.5rem;
      text-align: center;
      box-shadow: 0 20px 60px rgba(200,100,180,0.2);
      max-width: 420px;
      width: 90%;
    }

    .rabbit {
      font-size: 72px;
      display: block;
      animation: bounce 1.6s ease-in-out infinite;
      margin-bottom: 1rem;
    }
    @keyframes bounce {
      0%,100% { transform: translateY(0); }
      50%      { transform: translateY(-14px); }
    }

    h1 { font-size: 24px; font-weight: 900; color: #c84b8f; margin-bottom: 0.4rem; }
    p  { font-size: 16px; color: #999; margin-bottom: 2.5rem; }

    .btn-wrap {
      display: flex;
      gap: 16px;
      justify-content: center;
      align-items: center;
    }

    .btn-yes {
      padding: 14px 30px;
      font-size: 16px;
      font-weight: 700;
      font-family: 'Noto Sans KR', sans-serif;
      background: linear-gradient(135deg, #ff6eb4, #d44fa0);
      color: white;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(200,80,160,0.35);
      transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn-yes:hover  { transform: scale(1.06); box-shadow: 0 6px 20px rgba(200,80,160,0.5); }
    .btn-yes:active { transform: scale(0.97); }

    #noBtn {
      padding: 14px 30px;
      font-size: 16px;
      font-weight: 700;
      font-family: 'Noto Sans KR', sans-serif;
      background: #f0f0f0;
      color: #888;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      white-space: nowrap;
      user-select: none;
      position: fixed;
      transition: none;
    }

    /* Popup */
    .popup-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.35);
      backdrop-filter: blur(4px);
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }
    .popup-overlay.show { display: flex; }

    .popup-box {
      background: white;
      border-radius: 28px;
      padding: 2.5rem 3rem;
      text-align: center;
      box-shadow: 0 24px 60px rgba(0,0,0,0.2);
      animation: popIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
    }
    @keyframes popIn {
      from { transform: scale(0.7); opacity: 0; }
      to   { transform: scale(1);   opacity: 1; }
    }

    .popup-emoji { font-size: 56px; display: block; margin-bottom: 0.75rem; }
    .popup-title { font-size: 36px; font-weight: 900; color: #c84b8f; margin-bottom: 0.5rem; }
    .popup-sub   { font-size: 14px; color: #bbb; margin-bottom: 1.5rem; }
    .popup-close {
      padding: 10px 28px; font-size: 14px; font-weight: 700;
      font-family: 'Noto Sans KR', sans-serif;
      background: #f5f5f5; color: #888; border: none;
      border-radius: 50px; cursor: pointer;
    }
    .popup-close:hover { background: #ececec; }

    .hearts { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 998; }
    .heart  { position: absolute; animation: floatUp 1.5s ease-out forwards; }
    @keyframes floatUp {
      0%   { transform: translateY(0) scale(1); opacity: 1; }
      100% { transform: translateY(-300px) scale(0.5); opacity: 0; }
    }
  </style>
</head>
<body>

<div class="card">
  <span class="rabbit">🐰</span>
  <h1>안녕? 나 채은이야 ✨</h1>
  <p>우리 친구 할래?</p>
  <div class="btn-wrap">
    <button class="btn-yes" onclick="openPopup()">친구하자 🤝</button>
    <div id="noBtnPlaceholder" style="display:inline-block; width:0; height:0;"></div>
  </div>
</div>

<button id="noBtn">내가 왜? 😒</button>

<div class="popup-overlay" id="popup">
  <div class="popup-box">
    <span class="popup-emoji">🎉</span>
    <div class="popup-title">쵝오~!</div>
    <div class="popup-sub">우리 이제 친구야 🐰💕</div>
    <button class="popup-close" onclick="closePopup()">닫기</button>
  </div>
</div>

<div class="hearts" id="hearts"></div>

<script>
  const noBtn = document.getElementById('noBtn');
  const placeholder = document.getElementById('noBtnPlaceholder');

  // 버튼을 placeholder 위치에 딱 맞게 초기 배치
  function initBtnPosition() {
    const pr = placeholder.getBoundingClientRect();
    const bw = noBtn.offsetWidth;
    const bh = noBtn.offsetHeight;
    // placeholder 왼쪽 기준으로 배치 (btn-wrap gap 고려)
    noBtn.style.left = (pr.left - bw - 16) + 'px'; // gap 16px
    noBtn.style.top  = (pr.top + pr.height / 2 - bh / 2) + 'px';

    // 실제론 btn-yes 오른쪽에 붙이기
    const yesBtn = document.querySelector('.btn-yes');
    const yr = yesBtn.getBoundingClientRect();
    noBtn.style.left = (yr.right + 16) + 'px';
    noBtn.style.top  = (yr.top) + 'px';
  }

  window.addEventListener('load', initBtnPosition);
  window.addEventListener('resize', initBtnPosition);

  // 현재 버튼 중심 좌표 (fixed 기준)
  let btnX, btnY;

  function getBtnCenter() {
    const r = noBtn.getBoundingClientRect();
    return { x: r.left + r.width/2, y: r.top + r.height/2 };
  }

  document.addEventListener('mousemove', function(e) {
    const mx = e.clientX;
    const my = e.clientY;
    const c = getBtnCenter();
    const dx = c.x - mx;
    const dy = c.y - my;
    const dist = Math.sqrt(dx*dx + dy*dy);

    if (dist < 120) {
      // 마우스 반대 방향으로 도망
      const angle = Math.atan2(dy, dx);
      const flee = 150;

      const curLeft = parseFloat(noBtn.style.left) || 0;
      const curTop  = parseFloat(noBtn.style.top)  || 0;
      const bw = noBtn.offsetWidth;
      const bh = noBtn.offsetHeight;

      let newLeft = curLeft + Math.cos(angle) * flee;
      let newTop  = curTop  + Math.sin(angle) * flee;

      // 화면 경계
      newLeft = Math.max(0, Math.min(window.innerWidth  - bw, newLeft));
      newTop  = Math.max(0, Math.min(window.innerHeight - bh, newTop));

      noBtn.style.transition = 'left 0.15s ease, top 0.15s ease';
      noBtn.style.left = newLeft + 'px';
      noBtn.style.top  = newTop  + 'px';
    }
  });

  function openPopup() {
    document.getElementById('popup').classList.add('show');
    spawnHearts();
  }
  function closePopup() {
    document.getElementById('popup').classList.remove('show');
  }
  function spawnHearts() {
    const container = document.getElementById('hearts');
    container.innerHTML = '';
    const emojis = ['💕','🎉','✨','💖','🌸','🥳'];
    for (let i = 0; i < 20; i++) {
      const h = document.createElement('span');
      h.className = 'heart';
      h.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      h.style.left = (Math.random() * 100) + 'vw';
      h.style.top  = (50 + Math.random() * 40) + 'vh';
      h.style.fontSize = (16 + Math.random() * 20) + 'px';
      h.style.animationDelay = (Math.random() * 0.5) + 's';
      container.appendChild(h);
    }
    setTimeout(() => container.innerHTML = '', 2200);
  }
</script>
</body>
</html>
